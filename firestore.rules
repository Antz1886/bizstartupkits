rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Collection: Test (Health Check)
    match /test/connection {
      allow read: if true;
    }

    // Logic: Lead Validation
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'type', 'createdAt', 'status']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 5 && data.email.size() <= 200 &&
             data.type in ['Automation Assessment', 'AI Strategy Session', 'BI Demo', 'Free Assessment'] &&
             data.status == 'new';
    }

    // Collection: Leads
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow get, list: if isAdmin();
      allow delete: if isAdmin();
    }

    // Collection: Admins
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow read, write: if false; 
    }

    // Collection: SmeProfiles
    match /smeProfiles/{smeId} {
      allow read: if true; // In demo/sandbox mode, simple client lookup is allowed
      allow create, update: if isValidId(smeId) && 
                            incoming().keys().hasAll(['companyName', 'turnoverBracket', 'esdCategory', 'isVendorVerified', 'tasksCompleted']) &&
                            incoming().companyName is string &&
                            incoming().turnoverBracket in ['<R10m EME', 'R10m-R50m QSE', '>R50m Large'] &&
                            incoming().esdCategory in ['ED', 'SD'] &&
                            incoming().isVendorVerified is bool;
      allow delete: if isAdmin();
    }

    // Collection: CorporateSponsors
    match /corporateSponsors/{sponsorId} {
      allow read, write: if isValidId(sponsorId);
    }

    // Collection: AuditActivityLogs
    match /auditActivityLogs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) &&
                    incoming().keys().hasAll(['smeId', 'actionDescription', 'timestamp', 'isOfflineLogged']) &&
                    incoming().smeId is string &&
                    incoming().actionDescription is string &&
                    incoming().isOfflineLogged is bool;
    }

    // Collection: MentorshipMessages
    match /mentorshipMessages/{messageId} {
      allow read: if true;
      allow create: if isValidId(messageId) &&
                    incoming().keys().hasAll(['smeId', 'sponsorId', 'messageText', 'senderType', 'timestamp']) &&
                    incoming().smeId is string &&
                    incoming().sponsorId is string &&
                    incoming().messageText is string &&
                    incoming().senderType in ['SME', 'Sponsor'];
    }
  }
}
