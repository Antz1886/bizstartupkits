rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Collection: Test (Health Check)
    match /test/connection {
      allow read: if true;
    }

    // Logic: Lead Validation
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'type', 'createdAt', 'status']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 5 && data.email.size() <= 200 &&
             data.type in ['Automation Assessment', 'AI Strategy Session', 'BI Demo', 'Free Assessment'] &&
             data.createdAt == request.time &&
             data.status == 'new';
    }

    // Collection: Leads
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      allow get, list: if isAdmin();
      // Update and delete are forbidden even for admins to preserve integrity
      // If needed, delete could be allowed for admins
      allow delete: if isAdmin();
    }

    // Collection: Admins
    // This collection is strictly server-managed or manually bootstrapped
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      allow read, write: if false; // Only manageable via console or specialized tool
    }
  }
}
