{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Information collected from prospective clients via the website.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the prospect."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Work email address."
        },
        "type": {
          "type": "string",
          "enum": ["Automation Assessment", "AI Strategy Session", "BI Demo", "Free Assessment"],
          "description": "The specific service the prospect is interested in."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created."
        },
        "status": {
          "type": "string",
          "enum": ["new", "contacted", "qualified", "archived"],
          "description": "Current status of the lead in the sales pipeline."
        }
      },
      "required": ["name", "email", "type", "createdAt", "status"]
    },
    "Admin": {
      "title": "Admin",
      "description": "System administrators with access to view leads.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["super", "manager"]
        }
      },
      "required": ["email", "role"]
    },
    "SmeProfile": {
      "title": "SmeProfile",
      "description": "Profile details of a registered small business.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "turnoverBracket": {
          "type": "string",
          "enum": ["<R10m EME", "R10m-R50m QSE", ">R50m Large"]
        },
        "esdCategory": {
          "type": "string",
          "enum": ["ED", "SD"]
        },
        "isVendorVerified": { "type": "boolean" },
        "tasksCompleted": {
          "type": "object",
          "properties": {
            "cipcRegistered": { "type": "boolean" },
            "sarsTaxVerified": { "type": "boolean" },
            "bbbeeAffidavitCreated": { "type": "boolean" },
            "logoDesigned": { "type": "boolean" },
            "websiteLaunched": { "type": "boolean" },
            "whatsappBusinessActive": { "type": "boolean" },
            "invoiceGenerated": { "type": "boolean" }
          }
        },
        "sponsorId": { "type": "string" },
        "pendingGovernmentFiles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "offlineSyncPendingCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "turnoverBracket", "esdCategory", "isVendorVerified", "tasksCompleted", "createdAt"]
    },
    "CorporateSponsor": {
      "title": "CorporateSponsor",
      "description": "Enterprise sponsor supporting small businesses for B-BBEE compliance.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "financialYearEnd": {
          "type": "string",
          "enum": ["February", "June", "December"]
        },
        "targetNpatSpendZar": { "type": "number" },
        "sponsoredSmes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "financialYearEnd", "targetNpatSpendZar", "createdAt"]
    },
    "AuditActivityLog": {
      "title": "AuditActivityLog",
      "description": "Activity event logged for B-BBEE audit trail validation.",
      "type": "object",
      "properties": {
        "smeId": { "type": "string" },
        "actionDescription": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isOfflineLogged": { "type": "boolean" }
      },
      "required": ["smeId", "actionDescription", "timestamp", "isOfflineLogged"]
    },
    "MentorshipMessage": {
      "title": "MentorshipMessage",
      "description": "Coaching and mentorship interaction messages.",
      "type": "object",
      "properties": {
        "smeId": { "type": "string" },
        "sponsorId": { "type": "string" },
        "messageText": { "type": "string" },
        "senderType": {
          "type": "string",
          "enum": ["SME", "Sponsor"]
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["smeId", "sponsorId", "messageText", "senderType", "timestamp"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of all incoming consultation requests."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Whitelisted administrator accounts."
    },
    "/smeProfiles/{smeId}": {
      "schema": "SmeProfile",
      "description": "Small business growth dashboard profiles."
    },
    "/corporateSponsors/{sponsorId}": {
      "schema": "CorporateSponsor",
      "description": "Corporate enterprise sponsor dashboard configs."
    },
    "/auditActivityLogs/{logId}": {
      "schema": "AuditActivityLog",
      "description": "Immutable ledger of SME actions for SANAS B-BBEE verification."
    },
    "/mentorshipMessages/{messageId}": {
      "schema": "MentorshipMessage",
      "description": "Messages exchanged between mentors (sponsors) and beneficiaries (SMEs)."
    }
  }
}
